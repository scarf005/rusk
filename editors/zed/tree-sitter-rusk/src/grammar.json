{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rusk",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_token"
      }
    },
    "_token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attribute"
        },
        {
          "type": "SYMBOL",
          "name": "raw_string"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "char"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "builtin_type"
        },
        {
          "type": "SYMBOL",
          "name": "macro_identifier"
        },
        {
          "type": "SYMBOL",
          "name": "type_identifier"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "punctuation"
        }
      ]
    },
    "line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "attribute": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "#!?\\[[^\\]\\n]*\\]"
      }
    },
    "raw_string": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "r#*\"([^\"\\n]|\"[^#])*\"#*"
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"\\\\\\n]+"
                },
                {
                  "type": "PATTERN",
                  "value": "\\\\."
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "char": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "'"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^'\\\\\\n]"
              },
              {
                "type": "PATTERN",
                "value": "\\\\."
              }
            ]
          },
          {
            "type": "STRING",
            "value": "'"
          }
        ]
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\d[\\d_]*(\\.\\d[\\d_]*)?"
      }
    },
    "keyword": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "as"
          },
          {
            "type": "STRING",
            "value": "async"
          },
          {
            "type": "STRING",
            "value": "await"
          },
          {
            "type": "STRING",
            "value": "break"
          },
          {
            "type": "STRING",
            "value": "const"
          },
          {
            "type": "STRING",
            "value": "continue"
          },
          {
            "type": "STRING",
            "value": "crate"
          },
          {
            "type": "STRING",
            "value": "do"
          },
          {
            "type": "STRING",
            "value": "else"
          },
          {
            "type": "STRING",
            "value": "enum"
          },
          {
            "type": "STRING",
            "value": "extern"
          },
          {
            "type": "STRING",
            "value": "false"
          },
          {
            "type": "STRING",
            "value": "fn"
          },
          {
            "type": "STRING",
            "value": "for"
          },
          {
            "type": "STRING",
            "value": "if"
          },
          {
            "type": "STRING",
            "value": "impl"
          },
          {
            "type": "STRING",
            "value": "in"
          },
          {
            "type": "STRING",
            "value": "let"
          },
          {
            "type": "STRING",
            "value": "loop"
          },
          {
            "type": "STRING",
            "value": "match"
          },
          {
            "type": "STRING",
            "value": "mod"
          },
          {
            "type": "STRING",
            "value": "move"
          },
          {
            "type": "STRING",
            "value": "mut"
          },
          {
            "type": "STRING",
            "value": "pub"
          },
          {
            "type": "STRING",
            "value": "ref"
          },
          {
            "type": "STRING",
            "value": "return"
          },
          {
            "type": "STRING",
            "value": "Self"
          },
          {
            "type": "STRING",
            "value": "self"
          },
          {
            "type": "STRING",
            "value": "static"
          },
          {
            "type": "STRING",
            "value": "struct"
          },
          {
            "type": "STRING",
            "value": "then"
          },
          {
            "type": "STRING",
            "value": "trait"
          },
          {
            "type": "STRING",
            "value": "true"
          },
          {
            "type": "STRING",
            "value": "type"
          },
          {
            "type": "STRING",
            "value": "unsafe"
          },
          {
            "type": "STRING",
            "value": "use"
          },
          {
            "type": "STRING",
            "value": "where"
          },
          {
            "type": "STRING",
            "value": "while"
          }
        ]
      }
    },
    "builtin_type": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "bool"
          },
          {
            "type": "STRING",
            "value": "char"
          },
          {
            "type": "STRING",
            "value": "f32"
          },
          {
            "type": "STRING",
            "value": "f64"
          },
          {
            "type": "STRING",
            "value": "i8"
          },
          {
            "type": "STRING",
            "value": "i16"
          },
          {
            "type": "STRING",
            "value": "i32"
          },
          {
            "type": "STRING",
            "value": "i64"
          },
          {
            "type": "STRING",
            "value": "i128"
          },
          {
            "type": "STRING",
            "value": "isize"
          },
          {
            "type": "STRING",
            "value": "str"
          },
          {
            "type": "STRING",
            "value": "u8"
          },
          {
            "type": "STRING",
            "value": "u16"
          },
          {
            "type": "STRING",
            "value": "u32"
          },
          {
            "type": "STRING",
            "value": "u64"
          },
          {
            "type": "STRING",
            "value": "u128"
          },
          {
            "type": "STRING",
            "value": "usize"
          }
        ]
      }
    },
    "macro_identifier": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Za-z_][A-Za-z0-9_]*!"
      }
    },
    "type_identifier": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Z][A-Za-z0-9_]*"
      }
    },
    "identifier": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[a-z_][A-Za-z0-9_]*"
      }
    },
    "operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "=>"
          },
          {
            "type": "STRING",
            "value": "->"
          },
          {
            "type": "STRING",
            "value": "::"
          },
          {
            "type": "STRING",
            "value": "=="
          },
          {
            "type": "STRING",
            "value": "!="
          },
          {
            "type": "STRING",
            "value": "<="
          },
          {
            "type": "STRING",
            "value": ">="
          },
          {
            "type": "STRING",
            "value": "&&"
          },
          {
            "type": "STRING",
            "value": "||"
          },
          {
            "type": "STRING",
            "value": "+="
          },
          {
            "type": "STRING",
            "value": "-="
          },
          {
            "type": "STRING",
            "value": "*="
          },
          {
            "type": "STRING",
            "value": "/="
          },
          {
            "type": "STRING",
            "value": "%="
          },
          {
            "type": "PATTERN",
            "value": "[+\\-*\\/%=<>!&|.:?]+"
          }
        ]
      }
    },
    "punctuation": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[{}\\[\\](),;]"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "line_comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}