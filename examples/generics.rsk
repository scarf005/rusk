pub struct Boxed[T]:
    pub value: T

impl[T] Boxed[T]:
    pub fn new(value: T) -> Self = Self{ value }
    pub fn get(&self) -> &T = &self.value

pub fn parse_boxed(raw: &str) -> Result[Boxed[i32], std.num.ParseIntError]:
    let value = raw.parse[i32]()?
    Ok(Boxed.new(value))

pub fn main():
    match parse_boxed("42"):
        Ok(value) => println!("{}", value.get())
        Err(error) => eprintln!("{error}")
