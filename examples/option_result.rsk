pub fn first_positive(values: &[i32]) -> Option[i32] =
    for value in values
        if *value > 0
            return Some(*value)
    None

pub fn parse_positive(raw: &str) -> Result[Option[i32], std.num.ParseIntError] =
    let value = raw.parse[i32]()?
    if value > 0 then Ok(Some(value)) else Ok(None)
