pub fn parse_selected(lines: &[&str], index: usize) -> Result[Vec[i32], std.num.ParseIntError]:
    let picked = lines[index]
    let value = picked.parse[i32]()?
    let pair = [value, value + 1]
    Ok(Vec.from(pair))

pub fn main():
    match parse_selected(&["41"], 0):
        Ok(values) => println!("{:?}", values)
        Err(error) => eprintln!("{error}")
