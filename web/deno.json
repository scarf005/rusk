{
  "tasks": {
    "wasmbuild": "cd .. && deno run -A jsr:@deno/wasmbuild@0.19.3 -p rusk --out web/src/wasm --inline --skip-opt",
    "dev": "deno task wasmbuild && deno run -A --node-modules-dir npm:vite",
    "build": "deno task wasmbuild && deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "serve": "deno run --allow-net --allow-read jsr:@std/http@1/file-server dist/"
  },
  "fmt": {
    "semiColons": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "exclude": ["no-import-prefix"]
    }
  },
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "imports": {
    "@codemirror/commands": "npm:@codemirror/commands@^6.10.0",
    "@codemirror/lang-json": "npm:@codemirror/lang-json@^6.0.2",
    "@codemirror/lang-rust": "npm:@codemirror/lang-rust@^6.0.2",
    "@codemirror/language": "npm:@codemirror/language@^6.11.3",
    "@codemirror/state": "npm:@codemirror/state@^6.5.2",
    "@codemirror/view": "npm:@codemirror/view@^6.38.8",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
    "@preact/preset-vite": "npm:@preact/preset-vite@^2.10.2",
    "@preact/signals": "npm:@preact/signals@^1.3.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.0.0",
    "preact": "npm:preact@^10.28.0",
    "preact/hooks": "npm:preact@^10.28.0/hooks",
    "preact/jsx-runtime": "npm:preact@^10.28.0/jsx-runtime",
    "react/jsx-runtime": "npm:preact@^10.28.0/jsx-runtime",
    "tailwindcss": "npm:tailwindcss@^4.0.0",
    "vite": "npm:vite@^7.2.7",
    "wouter-preact": "npm:wouter-preact@3.9.0"
  }
}
